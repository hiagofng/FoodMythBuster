# Copy to .env and fill in values.
# The Makefile auto-exports everything in .env before running targets.

# --- Pipeline target: "duckdb" for local dev, "bigquery" for cloud ---
FOODMYTHBUSTER_TARGET=bigquery

# --- GCP (required when FOODMYTHBUSTER_TARGET=bigquery) ---
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=foodmythbuster-raw-your-suffix
BQ_DATASET=foodmythbuster
GCP_REGION=southamerica-east1

# --- Dashboard backend: "duckdb" or "bigquery" ---
FOODMYTHBUSTER_BACKEND=bigquery
